# ─── Store Selection ──────────────────────────────────────────────────────────
# Set one of these slugs to activate the corresponding store:
#
#   electromarket  →  ECOMMERCE  (tools, hardware)
#   adriano        →  RESTAURANT (Italian, Rome)
#   emmerka        →  RESTAURANT (café)
#   krajina        →  FOOD_MARKET (grocery delivery)
#   stepstyle      →  SHOE_MARKET (footwear)
#
STORE_SLUG=electromarket

# ─── Region & Locale ─────────────────────────────────────────────────────────
# UA → uk/ru/en (default: uk)
# EU → de/en/sk/cs (default: de)
REGION_BUNDLE=UA

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_SECRET=your-secret-here

# ─── AI (optional) ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
