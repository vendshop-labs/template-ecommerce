# ─── Store Selection ──────────────────────────────────────────────────────────
# Set one of these slugs to activate the corresponding store:
#
#   electromarket  →  ECOMMERCE    (tools / hardware)
#   krajina        →  FOOD_MARKET  (grocery delivery)
#   stepstyle      →  SHOE_MARKET  (footwear)
#   adriano        →  RESTAURANT   (Italian, Rome)
#   emmerka        →  RESTAURANT   (café)
#
STORE_SLUG=electromarket

# ─── Region & Locale ─────────────────────────────────────────────────────────
# UA → uk / ru / en  (default locale: uk)
# EU → de / en / sk / cs  (default locale: de)
REGION_BUNDLE=UA

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ─── Admin ───────────────────────────────────────────────────────────────────
# Must be changed in production — used to sign admin session tokens
ADMIN_SECRET=change-me-in-production

# ─── Public site URL ─────────────────────────────────────────────────────────
# Used for canonical URLs and Open Graph. On Vercel this is set automatically
# via VERCEL_PROJECT_PRODUCTION_URL; set it manually for custom domains.
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# ─── Vercel Blob (image uploads) ─────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# ─── AI admin assistant (optional) ───────────────────────────────────────────
# Provide at least one — the assistant picks whichever is available.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── NextAuth (if you add OAuth login) ───────────────────────────────────────
NEXTAUTH_SECRET=
